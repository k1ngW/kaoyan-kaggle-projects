# ============================================
# v23 Chris LogReg Stacker — Cell 1: Setup
# ============================================
import numpy as np
import pandas as pd
from pathlib import Path
import glob
import torch
import torch.nn as nn
from torch.optim import AdamW
from sklearn.model_selection import StratifiedKFold
from sklearn.metrics import balanced_accuracy_score
import warnings
warnings.filterwarnings('ignore')

# --- 固定配置 ---
SEEDS = [42, 142, 242, 342, 442]      # meta 模型 5 个 seed
N_META_FOLDS = 5                       # 每个 seed 内 5 fold
TARGET = 'class'
CLASSES = ['GALAXY', 'QSO', 'STAR']
N_CLASSES = len(CLASSES)
WEIGHT_DECAY = 0.01                    # L2 正则强度
LR = 0.01
EPOCHS = 200
DEVICE = 'cuda' if torch.cuda.is_available() else 'cpu'

print(f'Device: {DEVICE}  |  PyTorch: {torch.__version__}')
print(f'Meta seeds: {SEEDS}  |  Meta folds: {N_META_FOLDS}')
print(f'weight_decay={WEIGHT_DECAY}  LR={LR}  Epochs={EPOCHS}')


def safe_logit(p, eps=1e-15):
    """prob → logit，clip 防 ±inf"""
    p = np.clip(p, eps, 1 - eps)
    return np.log(p / (1 - p))


def inverse_logit(logit):
    """logit → prob (sigmoid)"""
    return 1 / (1 + np.exp(-logit))



# ============================================
# Cell 2: Auto-discover & load all OOF datasets
# ============================================

# --- Kaggle Dataset 路径（weywuy 下，2026-06-15 验证）---
OOF_BASE = '/kaggle/input/datasets/weywuy'
OOF_DATASETS = {
    'v8':    f'{OOF_BASE}/s6e6-v8-oof',
    'v17':   f'{OOF_BASE}/s6e6-cat-oof',
    'v18':   f'{OOF_BASE}/s6e6-realmlp5-oof',
    'v20':   f'{OOF_BASE}/s6e6-tabm-oof',
    'v22a':  f'{OOF_BASE}/s6e6-v22a-cat-oof',
}

def auto_load_oof(dataset_path, tag):
    """从 Kaggle Dataset 目录自动发现 .npy 文件"""
    import glob
    npy_files = glob.glob(f'{dataset_path}/**/*.npy', recursive=True)
    
    oof, test, bias = None, None, None
    for f in npy_files:
        fn = f.lower()
        if 'bias' in fn:
            bias = np.load(f)
        elif 'test' in fn:
            test = np.load(f)
        elif 'oof' in fn:
            oof = np.load(f)

    result = {}
    if oof is not None:  result['oof'] = oof.astype(np.float32)
    if test is not None: result['test'] = test.astype(np.float32)
    if bias is not None: result['bias'] = bias.astype(np.float32)
    
    def sh(arr):
        return str(arr.shape) if arr is not None else 'MISSING'
    
    print(f'  {tag:6s}  oof={sh(result.get("oof")):<20s}'
          f'  test={sh(result.get("test")):<20s}'
          f'  bias={sh(result.get("bias")) if "bias" in result else "—"}')
    return result

# --- 加载所有基模型的 OOF ---
print('Loading OOF datasets...\n')
all_oofs = {}
for name, path in OOF_DATASETS.items():
    all_oofs[name] = auto_load_oof(path, name)

# --- 验证形状一致性 ---
oof_shapes = [v['oof'].shape for v in all_oofs.values() if 'oof' in v]
test_shapes = [v['test'].shape for v in all_oofs.values() if 'test' in v]
assert len(set(oof_shapes)) == 1, f'OOF shapes differ: {set(oof_shapes)}'
assert len(set(test_shapes)) == 1, f'Test shapes differ: {set(test_shapes)}'
print(f'✓ All OOF aligned: {oof_shapes[0]} | All test aligned: {test_shapes[0]}')

# --- 读取 ground truth label ---
comp_root = '/kaggle/input/competitions/playground-series-s6e6'
train_csv = pd.read_csv(f'{comp_root}/train.csv')
y = train_csv[TARGET].map({c: i for i, c in enumerate(CLASSES)}).values.astype(np.int64)
test_csv = pd.read_csv(f'{comp_root}/test.csv')
test_ids = test_csv['id'].values
print(f'✓ Labels: {len(y)} samples, classes={dict(zip(*np.unique(y, return_counts=True)))}')

# --- prob → logit 变换 & 拼接 meta 特征 ---
meta_train_parts = []
meta_test_parts = []
channel_names = []

for name in ['v8', 'v17', 'v18', 'v20', 'v22a']:
    od = all_oofs[name]
    oof_logit = safe_logit(od['oof'])
    test_logit = safe_logit(od['test'])
    
    meta_train_parts.append(oof_logit)
    meta_test_parts.append(test_logit)
    
    for cls in CLASSES:
        channel_names.append(f'{name}_{cls}')

X_meta_train = np.hstack(meta_train_parts).astype(np.float64)  # float64 防溢出
X_meta_test  = np.hstack(meta_test_parts).astype(np.float64)

# 清理极端值（v18 RealMLP 有精确 0/1 概率）
X_meta_train = np.nan_to_num(X_meta_train, nan=0.0, posinf=0.0, neginf=0.0)
X_meta_test  = np.nan_to_num(X_meta_test, nan=0.0, posinf=0.0, neginf=0.0)
X_meta_train = np.clip(X_meta_train, -50, 50)
X_meta_test  = np.clip(X_meta_test, -50, 50)

print(f'\n✓ Meta features built:')
print(f'  X_meta_train: {X_meta_train.shape}  ({len(channel_names)} channels)')
print(f'  X_meta_test:  {X_meta_test.shape}')
print(f'  range: [{X_meta_train.min():.2f}, {X_meta_train.max():.2f}]')



# ============================================
# Cell 3: LogReg Stacker — 5 seed × 5 fold
# ============================================
from sklearn.preprocessing import StandardScaler

class LogRegStacker(nn.Module):
    """单层 Linear + CrossEntropy"""
    def __init__(self, n_features, n_classes):
        super().__init__()
        self.linear = nn.Linear(n_features, n_classes)
    def forward(self, x):
        return self.linear(x)


def compute_class_weights(y_tensor, n_classes):
    counts = torch.bincount(y_tensor, minlength=n_classes).float()
    weights = len(y_tensor) / (n_classes * counts)
    return weights


# --- 标准化 meta 特征 ---
scaler = StandardScaler()
X_meta_train_scaled = scaler.fit_transform(X_meta_train).astype(np.float32)
X_meta_test_scaled  = scaler.transform(X_meta_test).astype(np.float32)
print(f'Scaled range: [{X_meta_train_scaled.min():.2f}, {X_meta_train_scaled.max():.2f}]')

oof_meta = np.zeros((len(y), N_CLASSES), dtype=np.float32)
test_preds_sum = np.zeros((len(test_ids), N_CLASSES), dtype=np.float32)

PATIENCE = 30

for seed_idx, seed in enumerate(SEEDS):
    skf = StratifiedKFold(n_splits=N_META_FOLDS, shuffle=True, random_state=seed)
    
    for fold, (tr_idx, va_idx) in enumerate(skf.split(X_meta_train_scaled, y), start=1):
        run_name = f'seed={seed}  fold={fold}/{N_META_FOLDS}'
        
        X_tr = torch.tensor(X_meta_train_scaled[tr_idx], dtype=torch.float32, device=DEVICE)
        y_tr = torch.tensor(y[tr_idx], dtype=torch.long, device=DEVICE)
        X_va = torch.tensor(X_meta_train_scaled[va_idx], dtype=torch.float32, device=DEVICE)
        y_va = torch.tensor(y[va_idx], dtype=torch.long, device=DEVICE)
        X_te = torch.tensor(X_meta_test_scaled, dtype=torch.float32, device=DEVICE)
        
        model = LogRegStacker(X_meta_train_scaled.shape[1], N_CLASSES).to(DEVICE)
        optimizer = AdamW(model.parameters(), lr=0.001, weight_decay=WEIGHT_DECAY)
        
        best_loss = float('inf')
        best_state = {k: v.clone() for k, v in model.state_dict().items()}
        no_improve = 0
        
        for epoch in range(EPOCHS):
            model.train()
            optimizer.zero_grad()
            loss = criterion(model(X_tr), y_tr)
            loss.backward()
            torch.nn.utils.clip_grad_norm_(model.parameters(), max_norm=1.0)
            optimizer.step()
            
            model.eval()
            with torch.no_grad():
                va_loss = criterion(model(X_va), y_va).item()
            
            if va_loss < best_loss - 1e-6:
                best_loss = va_loss
                best_state = {k: v.clone() for k, v in model.state_dict().items()}
                no_improve = 0
            else:
                no_improve += 1
            
            if no_improve >= PATIENCE:
                break
        
        model.load_state_dict(best_state)
        model.eval()
        with torch.no_grad():
            va_prob = torch.softmax(model(X_va), dim=1).cpu().numpy()
            te_prob = torch.softmax(model(X_te), dim=1).cpu().numpy()
        
        oof_meta[va_idx] = va_prob.astype(np.float32)
        test_preds_sum += te_prob.astype(np.float32) / (len(SEEDS) * N_META_FOLDS)
        
        ba = balanced_accuracy_score(y[va_idx], np.argmax(va_prob, axis=1))
        stopped = f'(stopped @{epoch+1})' if no_improve >= PATIENCE else f'(epoch {epoch+1})'
        print(f'  {run_name:<26s}  loss={best_loss:.4f}  BA={ba:.6f}  {stopped}')
        
        del model, X_tr, y_tr, X_va, y_va, X_te

# --- 最终评估 ---
cv_ba = balanced_accuracy_score(y, np.argmax(oof_meta, axis=1))
print(f'\n{"="*55}')
print(f'Meta OOF Balanced Accuracy: {cv_ba:.8f}')
print(f'{"="*55}')
for i, cls_name in enumerate(CLASSES):
    mask = y == i
    cls_acc = (np.argmax(oof_meta[mask], axis=1) == i).mean()
    print(f'  {cls_name:8s}: {cls_acc:.6f}  ({mask.sum():,} samples)')



# ============================================
# Cell 4: Submission + 权重可解释性
# ============================================

# --- 全量训练一次，看权重 ---
X_full = torch.tensor(X_meta_train_scaled, dtype=torch.float32, device=DEVICE)
y_full = torch.tensor(y, dtype=torch.long, device=DEVICE)

final_model = LogRegStacker(X_meta_train_scaled.shape[1], N_CLASSES).to(DEVICE)
class_weights = compute_class_weights(y_full, N_CLASSES).to(DEVICE)
criterion = nn.CrossEntropyLoss(weight=class_weights)
optimizer = AdamW(final_model.parameters(), lr=0.001, weight_decay=WEIGHT_DECAY)

best_loss = float('inf')
best_state = {k: v.clone() for k, v in final_model.state_dict().items()}
no_improve = 0

for epoch in range(EPOCHS):
    final_model.train()
    optimizer.zero_grad()
    loss = criterion(final_model(X_full), y_full)
    loss.backward()
    torch.nn.utils.clip_grad_norm_(final_model.parameters(), max_norm=1.0)
    optimizer.step()
    
    final_model.eval()
    with torch.no_grad():
        cur_loss = criterion(final_model(X_full), y_full).item()
    
    if cur_loss < best_loss - 1e-6:
        best_loss = cur_loss
        best_state = {k: v.clone() for k, v in final_model.state_dict().items()}
        no_improve = 0
    else:
        no_improve += 1
    if no_improve >= PATIENCE:
        break

final_model.load_state_dict(best_state)
print(f'Full-data model: loss={best_loss:.4f}  (epoch {epoch+1-no_improve})\n')

# --- 权重分析 ---
weights = final_model.linear.weight.data.cpu().numpy()
bias = final_model.linear.bias.data.cpu().numpy()

print('═' * 70)
print('每个类 Top-5 最信任的通道（按 |weight| 排）：')
print('═' * 70)

for i, cls_name in enumerate(CLASSES):
    ranked = np.argsort(-np.abs(weights[i]))
    print(f'\n  {cls_name}  (bias={bias[i]:+.4f})')
    for j, idx in enumerate(ranked[:5]):
        w = weights[i, idx]
        bar = '█' * max(1, int(abs(w) * 80))
        sign = '+' if w > 0 else '-'
        print(f'    {j+1}. {channel_names[idx]:<22s}  {sign}{abs(w):.4f}  {bar}')

# --- 生成 submission ---
final_model.eval()
with torch.no_grad():
    test_prob = torch.softmax(final_model(
        torch.tensor(X_meta_test_scaled, dtype=torch.float32, device=DEVICE)
    ), dim=1).cpu().numpy()

pred_labels = [CLASSES[i] for i in np.argmax(test_prob, axis=1)]
submission = pd.DataFrame({'id': test_ids, 'class': pred_labels})
submission.to_csv('submission.csv', index=False)

print(f'\n{"─"*55}')
print(f'✓ submission.csv saved: {len(submission):,} rows')
print(f'  GALAXY: {(p := pred_labels).count("GALAXY"):,}  '
      f'QSO: {p.count("QSO"):,}  '
      f'STAR: {p.count("STAR"):,}')

np.save('v23_meta_oof.npy', oof_meta)
np.save('v23_meta_test.npy', test_prob)
print('✓ v23_meta_oof.npy + v23_meta_test.npy saved')



# ============================================
# Cell 5: 自动提交
# ============================================
import subprocess

COMP = 'playground-series-s6e6'
MSG = f'v23 Chris LogReg Stacker 5seed×5fold | OOF BA={cv_ba:.6f}'

result = subprocess.run(
    ['kaggle', 'competitions', 'submit', '-c', COMP, '-f', 'submission.csv', '-m', MSG],
    capture_output=True, text=True
)
print(result.stdout or '✓ 提交成功')
if result.returncode != 0:
    print('STDERR:', result.stderr)







