sub.head()





import numpy as np
from sklearn.model_selection import StratifiedKFold

cv = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)
oof = np.zeros((N, 3), dtype='float32')
test_preds_cv = np.zeros((M, 3), dtype='float32')

for fold, (tr_idx, va_idx) in enumerate(cv.split(X_train, y)):
    X_tr, X_va = X_train[tr_idx], X_train[va_idx]
    y_tr = train["class"].iloc[tr_idx]
    
    clf_fold = TabPFNClassifier(
        device=["cuda:0", "cuda:1"],
        n_estimators=2,
        balance_probabilities=True,
        random_state=42
    )
    clf_fold.fit(X_tr, y_tr)
    oof[va_idx] = clf_fold.predict_proba(X_va).astype('float32')
    test_preds_cv += clf_fold.predict_proba(X_test).astype('float32') / 5
    print(f'Fold {fold+1}/5 done')
    del clf_fold
    import gc; gc.collect()

np.save('v24_oof.npy', oof)
np.save('v24_test.npy', test_preds_cv)
np.save('v24_oof_labels.npy', y.values.astype('int8'))

cv_score = balanced_accuracy_score(y, oof.argmax(axis=1))
print(f'\nv24 5-fold CV: {cv_score:.5f}')

import json, datetime
meta = {
    "version": "v24",
    "date": str(datetime.datetime.now()),
    "cv_score": float(cv_score),
    "input_models": ["xgb-0", "xgb-1", "realmlp-0", "realmlp-1", "tabm-0", "cat-0"],
    "tabpfn_params": {"n_estimators": 2, "balance_probabilities": True, "random_state": 42},
    "n_features": int(X_train.shape[1]),
    "n_train": int(N),
    "n_test": int(M),
}
with open('v24_meta.json', 'w') as f:
    json.dump(meta, f, indent=2, default=str)
print('v24_meta.json saved')

